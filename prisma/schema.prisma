generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum VerificationCodePurpose {
  REGISTER
  RESET_PASSWORD
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum CatalogStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY_FOR_PICKUP
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
  FAILED
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          UserRole       @default(CUSTOMER)
  phone         String?
  avatarUrl     String?
  emailVerified DateTime?
  status        UserStatus     @default(ACTIVE)
  sessions      Session[]
  cart          Cart?
  orders        Order[]
  wishlistItems WishlistItem[]
  savedItems    SavedItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model EmailVerificationCode {
  id         String                  @id @default(cuid())
  email      String
  codeHash   String
  purpose    VerificationCodePurpose @default(REGISTER)
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int                     @default(0)
  createdAt  DateTime                @default(now())

  @@index([email, purpose, expiresAt])
}

model Category {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  image       String
  icon        String
  isFeatured  Boolean       @default(false)
  sortOrder   Int           @default(0)
  status      CatalogStatus @default(ACTIVE)
  products    Product[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, isFeatured, sortOrder])
}

model Brand {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  logo        String
  status      CatalogStatus @default(ACTIVE)
  products    Product[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, name])
}

model Product {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  sku              String         @unique
  brandId          String
  categoryId       String
  shortDescription String
  fullDescription  String
  price            Int
  salePrice        Int?
  stockQuantity    Int            @default(0)
  featuredImage    String
  tags             String         @default("[]")
  specifications   String         @default("{}")
  warrantyInfo     String
  status           ProductStatus  @default(ACTIVE)
  isFeatured       Boolean        @default(false)
  isNewArrival     Boolean        @default(false)
  isBestSeller     Boolean        @default(false)
  brand            Brand          @relation(fields: [brandId], references: [id], onDelete: Restrict)
  category         Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images           ProductImage[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  wishlistItems    WishlistItem[]
  savedItems       SavedItem[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([brandId])
  @@index([categoryId])
  @@index([status, isFeatured])
  @@index([status, isNewArrival])
  @@index([status, isBestSeller])
  @@index([status, price])
  @@index([status, createdAt])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId])
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId])
}

model SitePreference {
  id                          String   @id @default(cuid())
  siteName                    String   @default("CircuitHaus")
  storeTagline                String   @default("Premium technology market")
  logoUrl                     String   @default("")
  announcementText            String   @default("Premium launch deals are live")
  announcementEnabled         Boolean  @default(true)
  heroTitle                   String   @default("CircuitHaus")
  heroSubtitle                String   @default("Premium phones, creator laptops, gaming systems, cameras, and workstation accessories selected for speed, reliability, and long-term value.")
  heroImageUrl                String   @default("https://images.unsplash.com/photo-1513836279014-a89f7a76ae86?auto=format&fit=crop&w=1900&q=85")
  heroCtaText                 String   @default("Shop featured")
  heroCtaLink                 String   @default("/products?sort=featured")
  homepageBannerText          String   @default("Curated active catalog sections are controlled by product status and feature toggles.")
  featuredProductsTitle       String   @default("Premium picks with launch pricing")
  featuredProductsDescription String   @default("Launch selections spanning mobile, portable work, gaming systems, creator cameras, and desk upgrades.")
  newArrivalsTitle            String   @default("Fresh technology drops")
  newArrivalsDescription      String   @default("Recently added products from the active catalog, ready for the next phase of shopping flows.")
  bestSellersTitle            String   @default("Customer-favorite setups")
  bestSellersDescription      String   @default("Popular phones, laptops, creator gear, and accessories from the seeded catalog.")
  footerDescription           String   @default("A focused commerce foundation for premium devices, upgrade parts, creator gear, and support-ready technology products.")
  contactEmail                String   @default("")
  contactPhone                String   @default("")
  whatsappNumber              String   @default("")
  storeAddress                String   @default("")
  themeAccentColor            String   @default("#4f9ed8")
  featuredCategorySlugs       String   @default("[]")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model Order {
  id                   String        @id @default(cuid())
  orderNumber          String        @unique
  userId               String
  customerName         String
  customerEmail        String
  customerPhone        String
  shippingAddressLine1 String
  shippingAddressLine2 String        @default("")
  cityParishState      String
  country              String
  deliveryMethod       String        @default("DELIVERY")
  notes                String        @default("")
  subtotal             Int
  discountTotal        Int           @default(0)
  shippingTotal        Int           @default(0)
  taxTotal             Int           @default(0)
  total                Int
  status               OrderStatus   @default(PENDING)
  paymentStatus        PaymentStatus @default(UNPAID)
  stockRestoredAt      DateTime?
  user                 User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  items                OrderItem[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  productId           String
  productNameSnapshot String
  productSkuSnapshot  String
  priceSnapshot       Int
  salePriceSnapshot   Int?
  quantity            Int
  lineTotal           Int
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt           DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}
