generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum VerificationCodePurpose {
  REGISTER
  RESET_PASSWORD
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum CatalogStatus {
  ACTIVE
  INACTIVE
}

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  passwordHash  String
  role          UserRole   @default(CUSTOMER)
  phone         String?
  avatarUrl     String?
  emailVerified DateTime?
  status        UserStatus @default(ACTIVE)
  sessions      Session[]
  cart          Cart?
  wishlistItems WishlistItem[]
  savedItems    SavedItem[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model EmailVerificationCode {
  id         String                  @id @default(cuid())
  email      String
  codeHash   String
  purpose    VerificationCodePurpose @default(REGISTER)
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int                     @default(0)
  createdAt  DateTime                @default(now())

  @@index([email, purpose, expiresAt])
}

model Category {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  image       String
  icon        String
  isFeatured  Boolean       @default(false)
  sortOrder   Int           @default(0)
  status      CatalogStatus @default(ACTIVE)
  products    Product[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, isFeatured, sortOrder])
}

model Brand {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  logo        String
  status      CatalogStatus @default(ACTIVE)
  products    Product[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, name])
}

model Product {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  sku              String         @unique
  brandId          String
  categoryId       String
  shortDescription String
  fullDescription  String
  price            Int
  salePrice        Int?
  stockQuantity    Int            @default(0)
  featuredImage    String
  tags             String         @default("[]")
  specifications   String         @default("{}")
  warrantyInfo     String
  status           ProductStatus  @default(ACTIVE)
  isFeatured       Boolean        @default(false)
  isNewArrival     Boolean        @default(false)
  isBestSeller     Boolean        @default(false)
  brand            Brand          @relation(fields: [brandId], references: [id], onDelete: Restrict)
  category         Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images           ProductImage[]
  cartItems        CartItem[]
  wishlistItems    WishlistItem[]
  savedItems       SavedItem[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([brandId])
  @@index([categoryId])
  @@index([status, isFeatured])
  @@index([status, isNewArrival])
  @@index([status, isBestSeller])
  @@index([status, price])
  @@index([status, createdAt])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId])
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId])
}

model SitePreference {
  id                     String   @id @default(cuid())
  siteName               String   @default("CircuitHaus")
  storeTagline           String   @default("Premium technology market")
  logoUrl                String   @default("")
  announcementText       String   @default("Premium launch deals are live")
  announcementEnabled    Boolean  @default(true)
  heroTitle              String   @default("CircuitHaus")
  heroSubtitle           String   @default("Premium phones, creator laptops, gaming systems, cameras, and workstation accessories selected for speed, reliability, and long-term value.")
  heroCtaText            String   @default("Shop featured")
  heroCtaLink            String   @default("/products?sort=featured")
  homepageBannerText     String   @default("Curated active catalog sections are controlled by product status and feature toggles.")
  contactEmail           String   @default("")
  contactPhone           String   @default("")
  whatsappNumber         String   @default("")
  storeAddress           String   @default("")
  themeAccentColor       String   @default("#6e8f3d")
  featuredCategorySlugs  String   @default("[]")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
