DATABASE_URL="file:./dev.db"

# One-time registration code settings.
AUTH_CODE_PEPPER="replace-with-a-long-random-secret"
VERIFICATION_CODE_TTL_MINUTES="10"

# SMTP settings used to email account creation codes.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Store Demo <no-reply@example.com>"

# Optional local-only admin seed credentials. Do not use these values in production.
DEFAULT_ADMIN_NAME="Local Admin"
DEFAULT_ADMIN_EMAIL="admin@example.com"
DEFAULT_ADMIN_PASSWORD="ChangeThisLocalOnly123!"
